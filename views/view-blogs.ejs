<%- include('partials/head', { title: 'Blogs | adminHMD', description: 'View Blogs' }) %>

<body>
  <div class="admin-shell">
    <div class="sidebar-backdrop" data-sidebar-close></div>

    <%- include('partials/sidebar', { activePage: 'viewBlogs' }) %>

    <div class="admin-main">
      <%- include('partials/navbar') %>
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <h1 class="h3">Blogs</h1>
          </div>

          <section class="panel mt-3">
            <div class="panel-body">
              <% if (blogs && blogs.length) { %>
                <div class="list-group">
                  <% blogs.forEach(function(blog){ %>
                    <div class="list-group-item">
                      <div class="d-flex justify-content-between">
                        <div>
                          <h5 class="mb-1"><%= blog.title %></h5>
                          <small class="text-muted"><%= blog.createdAt.toDateString() %></small>
                          <% if (blog.image) { %>
                            <div class="my-2"><img src="<%= blog.image %>" alt="blog image" style="max-width:200px"></div>
                          <% } %>
                          <p class="mb-1"><%= blog.content.substring(0,200) %>...</p>
                        </div>
                        <div class="align-self-center">
                          <a class="btn btn-sm btn-outline-primary me-1" href="/pages/blog/<%= blog._id %>/edit">Edit</a>
                          <form action="/pages/blog/<%= blog._id %>/delete" method="post" style="display:inline-block">
                            <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                          </form>
                        </div>
                      </div>
                    </div>
                  <% }); %>
                </div>
              <% } else { %>
                <p>No blogs yet. <a href="/pages/blog/add">Create one</a></p>
              <% } %>
            </div>
          </section>
        </div>
      </main>
    </div>
  </div>

  <%- include('partials/footer') %>
  <%- include('partials/scripts') %>
</body>
</html>
